#!/usr/bin/expect -f
set timeout 120

spawn npx drizzle-kit push --force

while {1} {
    expect {
        "created or renamed from another" {
            send "\r"
            exp_continue
        }
        "Yes, I want to" {
            send "\r"
            exp_continue
        }
        eof {
            break
        }
        timeout {
            break
        }
    }
}

set result [wait]
exit [lindex $result 3]
